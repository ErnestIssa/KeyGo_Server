# Required in production (Render). Optional locally — dev falls back to mongodb://127.0.0.1:27017/keygo if unset.
MONGO_URI=mongodb://127.0.0.1:27017/keygo

# Render sets PORT automatically. For local dev you can set:
# PORT=3000

# Bind address (default 0.0.0.0 — correct for Render and LAN)
# HOST=0.0.0.0

# Production: your deployed frontend origin(s), comma-separated if needed
# CORS_ORIGIN=https://your-frontend.onrender.com

# NODE_ENV=production
